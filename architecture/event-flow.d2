# SSOT Event-Sourced Data Flow Architecture

direction: right

DataSources: {
  label: "Data Sources"
  style: { fill: "#F0FDF4", stroke: "#86EFAC" }
  FarmerOnboarding: { icon: user, label: "Farmer Onboarding\nvia BUD" }
  TradeExecution: { icon: swap, label: "Trade Execution\non Hemp Swap" }
  CertificateUpload: { icon: badge-check, label: "Certificate Upload\nfrom Labs" }
  ERPIntegration: { icon: gears, label: "ERP Integration\nAPIs" }
}

EventStream: {
  label: "Immutable Events"
  style: { fill: "#7C3AED", stroke: "#6D28D9" }
  Kafka: {
    label: "Apache Kafka"
    icon: lightning
    EntityVerified: { label: "EntityVerified", style: { fill: "#10B981" } }
    TradeExecuted: { label: "TradeExecuted", style: { fill: "#3B82F6" } }
    ComplianceUpdated: { label: "ComplianceUpdated", style: { fill: "#F59E0B" } }
    ValueTransferred: { label: "ValueTransferred", style: { fill: "#7C3AED" } }
    style: { nested_grid: 1 }
  }
  EventReplay: "Event Replay Capability"
}

GraphDatabase: {
  label: "Graph Database"
  style: { fill: "#065F46", stroke: "#047857" }
  icon: database
  AppendOnlyLog: "Append-Only\nEvent Log"
  StateReconstruction: "State\nReconstruction\nCapability"
  AuditTrail: "Audit Trail"
  style: { nested_grid: 1 }
}

DataConsumers: {
  label: "Data Consumers"
  style: { fill: "#FFFBEB", stroke: "#FCD34D" }
  AnalyticsEngine: { label: "Analytics\nEngine", icon: chart-bar }
  BUD_AI: { label: "BUD AI", icon: ai }
  ComplianceOracle: { label: "Compliance\nOracle", icon: shield }
  NADA_Ledger: { label: "NADA\nLedger", icon: coin }
  CQRS: "CQRS Pattern"
  style: { nested_grid: 1 }
}

DataSources -> EventStream.Kafka: "Event Publishing"
EventStream.Kafka -> GraphDatabase: "Event Persistence"
GraphDatabase -> DataConsumers: "State Queries"
EventStream.Kafka -> DataConsumers: "Event Stream (CQRS)"

Annotation1: {
  label: "No data is ever updated\nEvery action is an immutable event"
  style: { fill: "#FEF3C7", stroke: "#F59E0B", font_size: 11 }
}

Annotation2: {
  label: "Fully auditable\nProvable consistency"
  style: { fill: "#FEF3C7", stroke: "#F59E0B", font_size: 11 }
}

EventStream -> Annotation1: ""
GraphDatabase -> Annotation2: ""

style: {
  font_family: "Inter"
  border_radius: 10
  padding: 30
}
